#!/usr/bin/env bash
set -euo pipefail

# ─── agent-scaffold init ──────────────────────────────────────────
# Run from project root after cloning the scaffold.
# Creates project dirs, moves .gitignore to root, checks tools.
#
# Usage:
#   .claude/init
#   .claude/init --help
# ──────────────────────────────────────────────────────────────────

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "  ${GREEN}✅${NC} $1"; }
skip()  { echo -e "  ${YELLOW}⏭️${NC}  $1 (exists)"; }
warn()  { echo -e "  ${YELLOW}⚠️${NC}  $1"; }
fail()  { echo -e "  ${RED}❌${NC} $1"; }
step()  { echo -e "\n${BLUE}${BOLD}$1${NC}"; }

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "Usage: .claude/init"
    echo ""
    echo "Run from project root after cloning the scaffold:"
    echo "  git clone https://github.com/SandbergM/agent-scaffold.git my-project"
    echo "  cd my-project"
    echo "  rm -rf .git && git init"
    echo "  .claude/init"
    echo "  claude /kickoff"
    exit 0
fi

echo ""
echo -e "${BOLD}🏗️  agent-scaffold init${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ─── Project directories ─────────────────────────────────────────
step "📂 Creating project structure..."

for dir in src tests docs/specs docs/adr; do
    mkdir -p "$dir"
done
info "src/ tests/ docs/specs/ docs/adr/"

for dir in .claude/worklog/plans .claude/worklog/checklists .claude/worklog/sessions .claude/worklog/reviews; do
    mkdir -p "$dir"
done
info ".claude/worklog/{plans,checklists,sessions,reviews}"

# ─── Root files from .claude/ ────────────────────────────────────
step "📋 Setting up root files..."

if [ -f ".claude/.gitignore" ] && [ ! -f ".gitignore" ]; then
    cp .claude/.gitignore .gitignore
    info ".gitignore"
elif [ -f ".gitignore" ]; then
    skip ".gitignore"
fi

if [ ! -f ".env.example" ]; then
    cat > .env.example << 'ENV'
# ─── API Keys ────────────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── Database ────────────────────────────────
# DATABASE_URL=

# ─── App Config ──────────────────────────────
# APP_ENV=development
# LOG_LEVEL=info
ENV
    info ".env.example"
fi

# ─── Git ──────────────────────────────────────────────────────────
step "🔧 Git..."

if [ ! -d ".git" ]; then
    git init -q
    info "git init"
else
    skip "git already initialized"
fi

# ─── Prerequisites ────────────────────────────────────────────────
step "🔍 Checking tools..."

MISSING=0
check_tool() {
    local tool="$1" hint="$2" required="${3:-true}"
    if command -v "$tool" &> /dev/null; then
        info "$tool"
    elif [ "$required" = "true" ]; then
        fail "$tool — $hint"
        MISSING=$((MISSING + 1))
    else
        warn "$tool — $hint (optional)"
    fi
}

check_tool "claude" "npm install -g @anthropic-ai/claude-code"
check_tool "codex" "npm install -g @openai/codex (for MCP review)" "false"
check_tool "node" "Install Node.js 18+" "false"

# ─── Done ─────────────────────────────────────────────────────────
step "🚀 Ready!"
echo ""
echo -e "  Next: ${BOLD}claude /kickoff${NC}"
echo ""

if [ "$MISSING" -gt 0 ]; then
    echo -e "  ${RED}⚠️  $MISSING required tool(s) missing.${NC}"
    echo ""
fi
