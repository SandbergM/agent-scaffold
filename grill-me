#!/usr/bin/env bash
set -euo pipefail

# ─── grill-me ─────────────────────────────────────────────────────
# Shortcut to launch Claude Code with the /grill-me command.
# Starts an adversarial spec iteration session.
#
# Usage:
#   ./grill-me
#   ./grill-me "I want to build a price scraper for Swedish e-commerce"
# ──────────────────────────────────────────────────────────────────

# Check CLAUDE.md has been filled in
if grep -q "<!-- project name -->" CLAUDE.md 2>/dev/null; then
    echo "⚠️  CLAUDE.md has not been filled in yet."
    echo "   Run 'claude /kickoff' first to set up project context."
    echo ""
    read -p "Continue anyway? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 0
    fi
fi

if [ $# -ge 1 ]; then
    claude "/grill-me $*"
else
    claude "/grill-me"
fi
